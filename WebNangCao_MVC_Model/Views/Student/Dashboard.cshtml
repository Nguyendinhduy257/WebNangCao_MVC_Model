@{
    Layout = null; // Truy cập ...localhost:XXXX/Student/Dashboard
}
@model WebNangCao_MVC_Model.ViewModels.StudentDashboardViewModel

<!DOCTYPE html>
<html>
<head>
    <title>Dashboard Thí Sinh</title>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="~/css/student-dashboard.css" />
    <script src="https://unpkg.com/lucide@latest"></script>
</head>
<body class="dashboard-body">

    <header class="top-header">
        <a asp-controller="Account" asp-action="Index" class="btn-back">
            <i data-lucide="arrow-left" class="back-icon"></i>
            Quay lại
        </a>
        <div class="user-info">
            <span class="greeting">Xin chào, </span>
            @if (User.Identity != null && User.Identity.IsAuthenticated)
            {
                <span class="user-name">@User.Identity.Name</span>
            }

            <div class="avatar-container">
                <div class="avatar" id="userAvatar">N</div>

                <div class="avatar-dropdown" id="avatarDropdown">
                    <div class="dropdown-header">
                        <strong>Nguyễn Văn A</strong>
                        <span>student@example.com</span>
                    </div>
                    <ul class="dropdown-list">
                        <li><a href="#"><i data-lucide="user"></i> Hồ sơ cá nhân</a></li>
                        <li><a href="#"><i data-lucide="settings"></i> Cài đặt</a></li>
                        <li class="divider"></li>
                        <li>
                            <a href="/Account/Logout"
                               onclick="return confirm('Bạn có chắc chắn muốn đăng xuất?');"
                               class="text-danger">
                                <i data-lucide="log-out"></i> Đăng xuất
                            </a>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </header>

    <main class="dashboard-container">

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="custom-alert alert-success" id="successAlert">
                <i data-lucide="check-circle"></i> <span>@TempData["SuccessMessage"]</span>
                <button type="button" class="btn-close-alert"><i data-lucide="x"></i></button>
            </div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="custom-alert alert-danger" id="errorAlert">
                <i data-lucide="alert-circle"></i> <span>@TempData["ErrorMessage"]</span>
                <button type="button" class="btn-close-alert"><i data-lucide="x"></i></button>
            </div>
        }

        <section class="page-title" style="display: flex; justify-content: space-between; align-items: center;">
            <div>
                <h1>Dashboard Thí Sinh</h1>
                <p>Tìm kiếm và tham gia các bài thi</p>
            </div>
            <div style="display: flex; gap: 10px;">
                <button type="button" id="btnOpenPersonalExamModal" class="btn-create-exam" style="background: #4f46e5; color: white; border: none; padding: 10px 16px; border-radius: 8px; cursor: pointer; display: flex; align-items: center; gap: 8px;">
                    <i data-lucide="file-plus-2"></i> Tạo đề thi cá nhân
                </button>
                <button type="button" id="btnOpenJoinModal" class="btn-join-class">
                    <i data-lucide="plus-circle"></i> Tham gia lớp học
                </button>
            </div>
        </section>

        <section class="stats-grid">
            <div class="stat-card">
                <div class="stat-info">
                    <span class="stat-label">Tổng bài thi</span>
                    <span class="stat-value">@Model.TotalExams</span>
                </div>
                <div class="stat-icon bg-blue"><i data-lucide="file-text"></i></div>
            </div>
            <div class="stat-card">
                <div class="stat-info">
                    <span class="stat-label">Điểm trung bình</span>
                    <span class="stat-value">@Model.AverageScore</span>
                </div>
                <div class="stat-icon bg-green"><i data-lucide="trophy"></i></div>
            </div>
            <div class="stat-card">
                <div class="stat-info">
                    <span class="stat-label">Hoàn thành</span>
                    <span class="stat-value">@Model.CompletedExams/@Model.TotalExams</span>
                </div>
                <div class="stat-icon bg-purple"><i data-lucide="check-circle"></i></div>
            </div>
            <div class="stat-card">
                <div class="stat-info">
                    <span class="stat-label">Sắp tới</span>
                    <span class="stat-value">@Model.UpcomingExams</span>
                </div>
                <div class="stat-icon bg-orange"><i data-lucide="clock"></i></div>
            </div>
        </section>
        <!--giao diện hiển thị nhóm lớp đã tham gia-->
        <section class="class-section" id="classSection">
            <div class="exam-header" style="display: flex; justify-content: space-between; align-items: flex-start;">
                <div>
                    <h2><i data-lucide="users"></i> Lớp học đã tham gia</h2>
                    <p>Danh sách các lớp bạn đang là thành viên</p>
                </div>
                <button type="button" class="btn-toggle-section" onclick="toggleSection('classSection')">
                    <i data-lucide="chevron-up" class="icon-toggle"></i>
                </button>
            </div>

            <div class="section-content">
                <div class="class-grid">
                    @if (Model.JoinedClasses != null && Model.JoinedClasses.Count > 0)
                    {
                        @foreach (var cls in Model.JoinedClasses)
                        {
                            <div class="class-card">
                                <div class="class-card-header">
                                    <div class="class-icon"><i data-lucide="graduation-cap"></i></div>
                                    <div>
                                        <h3 title="@cls.ClassName">@cls.ClassName</h3>
                                        <span class="class-id">Mã: @cls.IdGroup</span>
                                    </div>
                                </div>
                                <div class="class-card-body">
                                    <p><i data-lucide="user"></i> GV: @cls.TeacherName</p>
                                    <p><i data-lucide="file-text"></i> @cls.ExamCount bài thi</p>
                                </div>
                                <div class="class-card-footer">
                                    <a href="javascript:void(0);" class="btn-view-class">Vào lớp học</a>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="empty-state-sm">
                            <i data-lucide="folder-open"></i>
                            <p>Bạn chưa tham gia lớp học nào.</p>
                        </div>
                    }
                </div>
            </div>
        </section>

        <section class="exam-section">
            <div class="exam-header">
                <h2><i data-lucide="list"></i> Danh sách các bài thi</h2>
                <p>Tìm thấy @(Model.Exams != null ? Model.Exams.Count : 0) bài thi</p>
            </div>

            <div class="search-filter-bar">
                <div class="search-box">
                    <i data-lucide="search"></i>
                    <input type="text" id="searchInput" placeholder="Tìm kiếm bài thi theo tên hoặc môn học..." />
                </div>
                <button class="btn-toggle-filter" id="btnToggleFilter">
                    <i data-lucide="filter"></i> Bộ lọc
                </button>
            </div>

            <div class="advanced-filter" id="advancedFilter">
                <div class="filter-group">
                    <label>Môn học</label>
                    <select id="filterSubject">
                        <option value="all">Tất cả môn học</option>
                        @if (Model.Exams != null && Model.Exams.Any())
                        {
                            // Lấy ra các môn học không bị null/rỗng và loại bỏ trùng lặp
                            var subjects = Model.Exams
                            .Where(e => !string.IsNullOrWhiteSpace(e.SubjectName))
                            .Select(e => e.SubjectName)
                            .Distinct();

                            foreach (var subject in subjects)
                            {
                                <option value="@subject">@subject</option>
                            }
                        }
                    </select>
                </div>

                <div class="filter-group">
                    <label>Trạng thái</label>
                    <select id="filterStatus">
                        <option value="all">Tất cả trạng thái</option>
                        @if (Model.Exams != null && Model.Exams.Any())
                        {
                            // Lấy ra các trạng thái thực tế đang có và loại bỏ trùng lặp
                            var statuses = Model.Exams
                            .Where(e => !string.IsNullOrWhiteSpace(e.Status))
                            .Select(e => e.Status)
                            .Distinct();

                            foreach (var status in statuses)
                            {
                                <option value="@status">@status</option>
                            }
                        }
                    </select>
                </div>

                <div class="filter-group">
                    <label>Độ khó</label>
                    <select id="filterDifficulty">
                        <option value="all">Tất cả độ khó</option>
                        @if (Model.Exams != null && Model.Exams.Any())
                        {
                            // Lấy ra các mức độ khó đang có và loại bỏ trùng lặp
                            var difficulties = Model.Exams
                            .Where(e => !string.IsNullOrWhiteSpace(e.Difficulty))
                            .Select(e => e.Difficulty)
                            .Distinct();

                            foreach (var diff in difficulties)
                            {
                                <option value="@diff">@diff</option>
                            }
                        }
                    </select>
                </div>
            </div>

            <div class="status-tabs">
                <button class="tab-btn active" data-tab="all">Tất cả (@Model.TotalExams)</button>
                <button class="tab-btn" data-tab="Có thể làm">Có thể làm (@Model.UpcomingExams)</button>
                <button class="tab-btn" data-tab="Sắp tới">Sắp tới (@Model.UpcomingExams)</button>
                <button class="tab-btn" data-tab="Đã hoàn thành">Đã hoàn thành (@Model.CompletedExams)</button>
            </div>

            <div class="exam-grid">
                @if (Model.Exams != null && Model.Exams.Count > 0)
                {
                    @foreach (var exam in Model.Exams)
                    {
                        var difficultyClass = exam.Difficulty?.ToLower() switch
                        {
                            "dễ" => "tag-green",
                            "trung bình" => "tag-orange",
                            "khó" => "tag-red",
                            _ => "tag-blue" // Mặc định nếu không khớp
                        };

                        <div class="exam-card data-item"
                             data-status="@exam.Status"
                             data-subject="@exam.SubjectName"
                             data-date="@exam.Status"
                             data-difficulty="@exam.Difficulty">

                            <div class="card-header">
                                <h3 title="@exam.Title">@exam.Title</h3>
                                @if (exam.Status == "Có thể làm")
                                {
                                    <span class="badge badge-success" title="Bạn có thể bắt đầu làm bài ngay bây giờ">
                                        <i data-lucide="unlock" style="width: 14px; height: 14px; margin-right: 4px;"></i> Có thể làm
                                    </span>
                                }
                                else if (exam.Status == "Sắp tới")
                                {
                                    <span class="badge badge-blue" title="Chưa đến thời gian làm bài">
                                        <i data-lucide="lock" style="width: 14px; height: 14px; margin-right: 4px;"></i> Sắp tới
                                    </span>
                                }
                                else
                                {
                                    <span class="badge badge-gray" title="Bạn đã hoàn thành bài thi này">
                                        <i data-lucide="check-circle-2" style="width: 14px; height: 14px; margin-right: 4px;"></i> Đã hoàn thành
                                    </span>
                                }
                            </div>

                            <div class="card-tags">
                                <span class="tag tag-blue"><i data-lucide="book" style="width: 12px; height: 12px; margin-right: 4px;"></i> @exam.SubjectName</span>
                                <span class="tag @difficultyClass">@exam.Difficulty</span>
                            </div>

                            <div class="card-details">
                                <div class="detail-item" title="Thời gian bắt đầu">
                                    <i data-lucide="calendar"></i> @exam.StartTime.ToString("dd/MM/yyyy HH:mm")
                                </div>
                                <div class="detail-item" title="Thời lượng làm bài">
                                    <i data-lucide="clock"></i> @exam.Duration phút
                                </div>
                                <div class="detail-item" title="Số lượng câu hỏi">
                                    <i data-lucide="file-text"></i> @exam.TotalQuestions câu hỏi
                                </div>
                                <div class="detail-item" title="Tên lớp học">
                                    <i data-lucide="users"></i> @exam.GroupName (Mã lớp: @exam.IdGroup)
                                </div>
                            </div>

                            <div class="card-actions" style="margin-top: auto; padding-top: 16px;">
                                @if (exam.Status == "Có thể làm")
                                {
                                    <a asp-controller="TestAttempt"
                                       asp-action="GiaoDienLamBai"
                                       asp-route-id="@exam.Id"
                                       class="btn-primary-action"
                                       style="text-decoration: none; display: flex; align-items: center; justify-content: center; gap: 8px; width: 100%;">
                                        <i data-lucide="play-circle"></i> Bắt đầu làm bài
                                    </a>
                                }
                                else if (exam.Status == "Sắp tới")
                                {
                                    <button class="btn-disabled" disabled style="width: 100%; display: flex; align-items: center; justify-content: center; gap: 8px;">
                                        <i data-lucide="history"></i> Chưa tới giờ thi
                                    </button>
                                }
                                else
                                {
                                    <button class="btn-disabled" disabled style="background-color: #f1f5f9; color: #64748b; border: 1px dashed #cbd5e1; width: 100%; display: flex; align-items: center; justify-content: center; gap: 8px;">
                                        <i data-lucide="check-circle"></i> Đã hoàn thành
                                    </button>
                                }
                            </div>
                        </div>
                    }
                }
                //dùng cho tài khoản mới hoàn toàn mà chưa có bài thi nào

                else
                {
                    <div class="empty-state" style="grid-column: 1 / -1; display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center; padding: 60px 20px; color: #64748b; background: #f8fafc; border-radius: 12px; border: 1px dashed #e2e8f0;">
                        <i data-lucide="inbox" style="width: 64px; height: 64px; margin-bottom: 16px; opacity: 0.4; color: #94a3b8;"></i>
                        <h3 style="margin: 0 0 8px 0; color: #334155;">Không có bài thi nào</h3>
                        <p style="margin: 0; font-size: 14px;">Bạn chưa có bài thi nào từ các lớp đã tham gia.</p>
                    </div>
                }
            </div>
            <div id="jsEmptyState" style="display: none; flex-direction: column; align-items: center; justify-content: center; text-align: center; padding: 60px 20px; color: #64748b; background: #f8fafc; border-radius: 12px; border: 1px dashed #e2e8f0; margin-bottom: 20px;">
                <i data-lucide="search-x" style="width: 64px; height: 64px; margin-bottom: 16px; opacity: 0.4; color: #94a3b8;"></i>
                <h3 style="margin: 0 0 8px 0; color: #334155;">Không tìm thấy bài thi phù hợp</h3>
                <p style="margin: 0; font-size: 14px;">Thử thay đổi điều kiện bộ lọc hoặc tìm kiếm từ khóa khác xem sao.</p>
            </div>

            <div class="pagination-container">
                <button id="prevPage" class="btn-page">
                    <i data-lucide="chevron-left"></i>
                </button>

                <div id="pageNumbers" class="page-numbers">
                </div>

                <button id="nextPage" class="btn-page">
                    <i data-lucide="chevron-right"></i>
                </button>
            </div>
        </section>

    </main>

    <div class="custom-modal-overlay" id="joinClassModal">
        <div class="custom-modal">
            <div class="modal-header">
                <h3>Gia nhập lớp học mới</h3>
                <button type="button" id="btnCloseJoinModal" class="btn-icon-close"><i data-lucide="x"></i></button>
            </div>
            <form action="/Student/JoinClass" method="post">
                <div class="modal-body">
                    <label for="groupId" style="display:block; margin-bottom:8px; font-weight:600;">Mã Lớp Học (ID):</label>
                    <input type="number" id="groupId" name="groupId" placeholder="Nhập mã lớp..." required min="1" class="form-control-custom">
                    <small style="color:#64748b; display:block; margin-top:8px;">Ví dụ: 1, 2, 3...</small>
                </div>
                <div class="modal-footer">
                    <button type="button" id="btnCancelJoinModal" class="btn-cancel">Hủy</button>
                    <button type="submit" class="btn-submit">Xác nhận tham gia</button>
                </div>
            </form>
        </div>
    </div>
    <!--Modal thêm bài làm cá nhân-->
    <div class="custom-modal-overlay" id="personalExamModal">
        <div class="custom-modal" style="width: 500px;">
            <div class="modal-header">
                <h3>Tạo Đề Thi Cá Nhân (Upload Excel)</h3>
                <button type="button" id="btnClosePersonalModal" class="btn-icon-close"><i data-lucide="x"></i></button>
            </div>
            <div class="modal-body">
                <div id="dropZone" style="border: 2px dashed #cbd5e1; border-radius: 12px; padding: 40px 20px; text-align: center; cursor: pointer; background: #f8fafc; transition: all 0.3s;">
                    <i data-lucide="upload-cloud" style="width: 48px; height: 48px; color: #64748b; margin-bottom: 16px;"></i>
                    <h4 style="margin: 0 0 8px 0; color: #334155;">Kéo thả file Excel vào đây</h4>
                    <p style="margin: 0; font-size: 14px; color: #64748b;">hoặc click để chọn file (.xlsx, .xls)</p>
                    <input type="file" id="fileInput" accept=".xlsx, .xls" style="display: none;" />
                </div>

                <div id="errorContainer" style="display: none; margin-top: 16px; max-height: 200px; overflow-y: auto; background: #fef2f2; border: 1px solid #fecaca; border-radius: 8px; padding: 12px;">
                    <h5 style="margin: 0 0 8px 0; color: #ef4444;"><i data-lucide="alert-triangle" style="width: 16px; height: 16px;"></i> Phát hiện lỗi trong file:</h5>
                    <ul id="errorList" style="margin: 0; padding-left: 20px; color: #b91c1c; font-size: 13px;"></ul>
                </div>

                <div style="margin-top: 20px; text-align: center;">
                    <p style="font-size: 13px; color: #64748b;">
                        @if (ViewBag.LatestExamId != null)
                        {
                            <span>Bạn có một đề thi đang tạo: </span>
                            <br />
                            <a href="@Url.Action("ClassifyExam", "Student", new { examId = ViewBag.LatestExamId })"
                               style="color: #4f46e5; font-weight: 600;">
                                Tiếp tục phân loại [@ViewBag.LatestExamTitle]
                            </a>
                        }
                        else
                        {
                            <a href="/Student/PersonalExamsList" style="color: #64748b; font-weight: 600;">
                                Xem danh sách đề thi đã tạo
                            </a>
                        }
                    </p>
                </div>
            </div>
        </div>
    </div>
    
    <script>
        // Kích hoạt icon Lucide
        lucide.createIcons();
    </script>
    <script src="~/js/student-dashboard.js"></script>
</body>
</html>