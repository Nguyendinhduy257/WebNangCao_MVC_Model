@using WebNangCao_MVC_Model.ViewModels
@model ClassCreateViewModel

@{
    ViewData["Title"] = "Tạo Lớp Học Mới";
}

<div class="container-fluid">
    <div class="row">
        <div class="col-md-8 offset-md-2">
            <h2><i class="fas fa-plus-circle"></i> Tạo Lớp Học Mới</h2>
            <hr />

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <strong>Lỗi!</strong> Vui lòng kiểm tra lại các trường thông tin bên dưới.
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            <form method="post" novalidate>
                <div class="mb-3">
                    <label asp-for="GroupName" class="form-label">Tên Lớp Học <span class="text-danger">*</span></label>
                    <input asp-for="GroupName" class="form-control" placeholder="Ví dụ: Lớp Toán 12A1" required>
                        <span asp-validation-for="GroupName" class="text-danger d-block mt-1"></span>
                        <small class="text-muted">3-100 ký tự</small>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Description" class="form-label">Mô Tả <span class="text-danger">*</span></label>
                        <textarea asp-for="Description" class="form-control" rows="4" placeholder="Nhập mô tả lớp học..." required></textarea>
                        <span asp-validation-for="Description" class="text-danger d-block mt-1"></span>
                        <small class="text-muted">10-500 ký tự</small>
                    </div>

                    <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                        <a href="@Url.Action("Classes")" class="btn btn-secondary">Hủy</a>
                        <button type="submit" class="btn btn-primary">
                            <i class="fas fa-save"></i> Tạo Lớp
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    @section Scripts {
        @{
            await Html.RenderPartialAsync("_ValidationScriptsPartial");
        }
    }