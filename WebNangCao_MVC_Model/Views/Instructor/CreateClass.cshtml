@using WebNangCao_MVC_Model.ViewModels
@model ClassCreateViewModel

@{
    ViewData["Title"] = "Tạo Lớp Học Mới";
}

<div class="container-fluid">
    <div class="row">
        <div class="col-md-8 offset-md-2">
            <h2><i class="fas fa-plus-circle"></i> Tạo Lớp Học Mới</h2>
            <hr />

            <form method="post">
                <div class="mb-3">
                    <label asp-for="GroupName" class="form-label">Tên Lớp Học</label>
                    <input asp-for="GroupName" class="form-control" placeholder="Ví dụ: Lớp Toán 12A1">
                        <span asp-validation-for="GroupName" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Description" class="form-label">Mô Tả</label>
                        <textarea asp-for="Description" class="form-control" rows="4" placeholder="Nhập mô tả lớp học..."></textarea>
                        <span asp-validation-for="Description" class="text-danger"></span>
                    </div>

                    <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                        <a href="@Url.Action("Classes")" class="btn btn-secondary">Hủy</a>
                        <button type="submit" class="btn btn-primary">
                            <i class="fas fa-save"></i> Tạo Lớp
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>